<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <div class="top-actions">
            <h1>All Posts</h1>
            <a class="new-link" href="/posts/new">New Post</a>
        </div>

        <div class="posts-grid">
        <% for(post of posts) { %>
            <div class="post-card">
                <h3>@<%= post.username %></h3>
                <p><%= post.content %></p>
                <br>
                <div class="card-actions">
                    <a class="details-link" href="/posts/<%= post.id %>">View Details</a>
                    <a class="edit-link" href="/posts/<%= post.id %>/edit">Edit</a>
                    <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Delete this post?');">
                        <button class="btn btn-danger" type="submit">Delete</button>
                    </form>
                </div>
            </div>
        <% } %>
        </div>
    </div>
</body>
</html>