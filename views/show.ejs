<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post Details</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>Post Details</h1>
        <div class="post-card post-details">
            <h3>@<%= post.username %></h3>
            <p><%= post.content %></p>
            <div class="card-actions">
                <a class="edit-link" href="/posts/<%= post.id %>/edit">Edit</a>
                <form action="/posts/<%= post.id %>?_method=DELETE" method="POST" style="display:inline;" onsubmit="return confirm('Delete this post?');">
                    <button class="btn btn-danger" type="submit">Delete</button>
                </form>
                <a class="details-link" href="/posts">Back</a>
            </div>
        </div>
    </div>
</body>
</html>